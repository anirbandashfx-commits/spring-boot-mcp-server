hs_err_pid*
replay_pid*

# === MCP Server specific ===

# Never commit secrets or local config
application-local.yml
application-local.properties
*.env
.env
.env.*

# Never commit your actual DB credentials
application.yml
# Only commit application.yml.example (a safe template)

# IDE files
.idea/
*.iml
.vscode/settings.json

# Build output
target/
*.jar
*.war

# OS junk
.DS_Store
Thumbs.db

